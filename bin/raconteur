#!/usr/bin/env python3
"""Raconteur entry point.

Symlink this file into your PATH:
    ln -s /path/to/raconteur/bin/raconteur ~/.local/bin/raconteur
"""
import sys
from pathlib import Path

# When run directly or via symlink, resolve back to the repo root
# so the raconteur package is importable without a pip install.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from raconteur.cli import main

if __name__ == "__main__":
    main()
